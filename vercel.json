{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/privacidade",
      "dest": "/privacidade.html"
    },
    {
      "src": "/termos",
      "dest": "/termos.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}